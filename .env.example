# Copie para .env (LOCAL). Em PRODUÇÃO (Render), configure como Environment Variables.

# Segurança
SECRET_KEY=troque-por-uma-chave-grande-e-secreta
DEBUG=0

# Hosts (separe por vírgula). Ex: estetica.onrender.com,seu-dominio.com
ALLOWED_HOSTS=127.0.0.1,localhost

# CSRF (urls com https). Ex: https://estetica.onrender.com,https://seu-dominio.com
CSRF_TRUSTED_ORIGINS=

# Banco (Render Postgres fornece DATABASE_URL)
DATABASE_URL=

# Forçar HTTPS atrás de proxy (Render): 1 = sim
SECURE_PROXY_SSL_HEADER=1
